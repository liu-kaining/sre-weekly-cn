---
import ScoreBadge from './ScoreBadge.astro';

interface Props {
  id: string;
  titleCn: string;
  title: string;
  category: string;
  tags: string[];
  score: number;
  summaryCn: string;
  issueNumber: number;
}

const { id, titleCn, title, category, tags, score, summaryCn, issueNumber } = Astro.props;

const categoryLabels: Record<string, string> = {
  'incident-report': '事故报告',
  'monitoring-observability': '监控可观测',
  'reliability-engineering': '可靠性工程',
  'platform-engineering': '平台工程',
  'devops-culture': 'DevOps文化',
  'chaos-engineering': '混沌工程',
  'on-call-response': '值班响应',
  'performance': '性能优化',
  'security-reliability': '安全可靠性',
  'misc': '其他',
};
---

<article class="border border-border rounded-lg p-5 bg-surface hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-3 mb-2">
    <a href={`/articles/${id}`} class="text-lg font-semibold text-text hover:text-primary transition-colors leading-tight">
      {titleCn}
    </a>
    <ScoreBadge score={score} />
  </div>
  <p class="text-xs text-text-secondary mb-2">{title}</p>
  <p class="text-sm text-text-secondary mb-3 line-clamp-2">{summaryCn}</p>
  <div class="flex items-center justify-between">
    <div class="flex flex-wrap gap-1.5">
      <span class="text-xs px-2 py-0.5 bg-primary/10 text-primary rounded">
        {categoryLabels[category] || category}
      </span>
      {tags.slice(0, 3).map((tag) => (
        <a href={`/tags/${tag}`} class="text-xs px-2 py-0.5 bg-gray-100 text-gray-600 rounded hover:bg-gray-200">
          {tag}
        </a>
      ))}
    </div>
    <span class="text-xs text-text-secondary">#{issueNumber}</span>
  </div>
</article>
