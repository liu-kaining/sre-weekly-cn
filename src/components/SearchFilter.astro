---
interface Props {
  categories: { value: string; label: string }[];
  allTags: string[];
}

const { categories, allTags } = Astro.props;
---

<div id="search-filter" class="mb-8 space-y-4">
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="flex flex-1 gap-2">
      <input
        type="text"
        id="search-input"
        placeholder="搜索文章标题或摘要..."
        class="flex-1 px-4 py-2 border border-border rounded-lg bg-surface focus:outline-none focus:ring-2 focus:ring-primary/50"
      />
      <button
        id="search-button"
        class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50"
      >
        搜索
      </button>
    </div>
    <select
      id="category-filter"
      class="px-4 py-2 border border-border rounded-lg bg-surface focus:outline-none focus:ring-2 focus:ring-primary/50"
    >
      <option value="">全部分类</option>
      {categories.map((cat) => (
        <option value={cat.value}>{cat.label}</option>
      ))}
    </select>
    <select
      id="score-filter"
      class="px-4 py-2 border border-border rounded-lg bg-surface focus:outline-none focus:ring-2 focus:ring-primary/50"
    >
      <option value="">全部评分</option>
      <option value="8">8分以上</option>
      <option value="6">6分以上</option>
      <option value="4">4分以上</option>
    </select>
  </div>
</div>

<script define:vars={{ allTags }}>
  const searchInput = document.getElementById('search-input');
  const searchButton = document.getElementById('search-button');
  const categoryFilter = document.getElementById('category-filter');
  const scoreFilter = document.getElementById('score-filter');
  const articles = document.querySelectorAll('[data-article]');

  function filterArticles() {
    const query = searchInput.value.toLowerCase();
    const category = categoryFilter.value;
    const minScore = parseInt(scoreFilter.value) || 0;

    articles.forEach((article) => {
      const title = article.dataset.title?.toLowerCase() || '';
      const titleCn = article.dataset.titleCn?.toLowerCase() || '';
      const summary = article.dataset.summary?.toLowerCase() || '';
      const articleCategory = article.dataset.category || '';
      const score = parseInt(article.dataset.score) || 0;

      const matchesSearch = !query || title.includes(query) || titleCn.includes(query) || summary.includes(query);
      const matchesCategory = !category || articleCategory === category;
      const matchesScore = score >= minScore;

      article.style.display = matchesSearch && matchesCategory && matchesScore ? '' : 'none';
    });
  }

  searchInput.addEventListener('input', filterArticles);
  searchButton.addEventListener('click', filterArticles);
  searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      filterArticles();
    }
  });
  categoryFilter.addEventListener('change', filterArticles);
  scoreFilter.addEventListener('change', filterArticles);
</script>
