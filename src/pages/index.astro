---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

// 统计数据
const totalArticles = articles.length;
const categories = [...new Set(articles.map((a) => a.data.category))];
const totalCategories = categories.length;
const allTags = [...new Set(articles.flatMap((a) => a.data.tags))];
const totalTags = allTags.length;
const issues = [...new Set(articles.map((a) => a.data.issueNumber))];
const totalIssues = issues.length;
---

<BaseLayout title="首页">
  <section class="mb-10">
    <h1 class="text-3xl font-bold mb-2">SRE Weekly 中文版</h1>
    <p class="text-text-secondary mb-6">AI驱动的SRE周刊内容聚合 — 每日自动翻译、评析、分类</p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="p-4 bg-surface border border-border rounded-lg text-center">
        <div class="text-3xl font-bold text-primary">{totalArticles}</div>
        <div class="text-sm text-text-secondary">篇文章</div>
      </div>
      <div class="p-4 bg-surface border border-border rounded-lg text-center">
        <div class="text-3xl font-bold text-primary">{totalIssues}</div>
        <div class="text-sm text-text-secondary">期周刊</div>
      </div>
      <div class="p-4 bg-surface border border-border rounded-lg text-center">
        <div class="text-3xl font-bold text-primary">{totalCategories}</div>
        <div class="text-sm text-text-secondary">个分类</div>
      </div>
      <div class="p-4 bg-surface border border-border rounded-lg text-center">
        <div class="text-3xl font-bold text-primary">{totalTags}</div>
        <div class="text-sm text-text-secondary">个标签</div>
      </div>
    </div>

    <div class="p-4 bg-blue-50 border border-blue-200 rounded-lg text-sm">
      <p class="text-blue-900">
        本站内容来源于 <a href="https://sreweekly.com" class="font-semibold text-primary hover:underline" target="_blank" rel="noopener">SRE Weekly (sreweekly.com)</a>，
        由 AI 自动翻译并加以点评，仅供中文读者参考学习。
        本站为非官方二次加工站点，建议同时关注 <a href="https://sreweekly.com" class="font-semibold text-primary hover:underline" target="_blank" rel="noopener">原站</a> 获取第一手英文内容。
      </p>
    </div>
  </section>

  <div class="grid gap-4">
    {articles.map((article) => (
      <ArticleCard
        id={article.id}
        titleCn={article.data.titleCn}
        title={article.data.title}
        category={article.data.category}
        tags={article.data.tags}
        score={article.data.score}
        summaryCn={article.data.summaryCn}
        issueNumber={article.data.issueNumber}
      />
    ))}
  </div>

  {articles.length === 0 && (
    <div class="text-center py-16 text-text-secondary">
      <p class="text-lg">暂无文章</p>
      <p class="mt-2 text-sm">运行 <code class="bg-gray-100 px-2 py-0.5 rounded">npm run sync</code> 来获取最新内容</p>
    </div>
  )}
</BaseLayout>
