---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({
    params: { number: String(issue.data.issueNumber) },
    props: { issue },
  }));
}

const { issue } = Astro.props;
const articles = (await getCollection('articles'))
  .filter((a) => a.data.issueNumber === issue.data.issueNumber)
  .sort((a, b) => b.data.score - a.data.score);
---

<BaseLayout title={`#${issue.data.issueNumber} - ${issue.data.title}`}>
  <div class="mb-6">
    <a href="/issues" class="text-sm text-primary hover:underline">&larr; 返回期刊列表</a>
  </div>

  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2">#{issue.data.issueNumber} {issue.data.title}</h1>
    <div class="flex items-center gap-4 text-text-secondary text-sm">
      <span>{new Date(issue.data.date).toLocaleDateString('zh-CN')}</span>
      <span>{articles.length} 篇文章</span>
      <a href={issue.data.url} class="text-primary hover:underline" target="_blank" rel="noopener">
        查看原文
      </a>
    </div>
  </header>

  <div class="grid gap-4">
    {articles.map((article) => (
      <ArticleCard
        id={article.id}
        titleCn={article.data.titleCn}
        title={article.data.title}
        category={article.data.category}
        tags={article.data.tags}
        score={article.data.score}
        summaryCn={article.data.summaryCn}
        issueNumber={article.data.issueNumber}
      />
    ))}
  </div>
</BaseLayout>
