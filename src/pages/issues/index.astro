---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const issues = (await getCollection('issues')).sort(
  (a, b) => b.data.issueNumber - a.data.issueNumber
);
---

<BaseLayout title="期刊列表">
  <h1 class="text-3xl font-bold mb-6">期刊列表</h1>

  <div class="grid gap-3">
    {issues.map((issue) => (
      <a
        href={`/issues/${issue.data.issueNumber}`}
        class="flex items-center justify-between p-4 border border-border rounded-lg bg-surface hover:shadow-md transition-shadow"
      >
        <div>
          <span class="font-semibold">#{issue.data.issueNumber}</span>
          <span class="ml-3 text-text-secondary">{issue.data.title}</span>
        </div>
        <div class="flex items-center gap-4 text-sm text-text-secondary">
          <span>{issue.data.articleCount} 篇文章</span>
          <span>{new Date(issue.data.date).toLocaleDateString('zh-CN')}</span>
        </div>
      </a>
    ))}
  </div>

  {issues.length === 0 && (
    <div class="text-center py-16 text-text-secondary">
      <p class="text-lg">暂无期刊</p>
    </div>
  )}
</BaseLayout>
